{
  "name": "slidev_agent",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "slidev slides.md --port 3030",
    "build": "slidev build slides.md",
    "export:pdf": "slidev export slides.md --output ./output/illness-and-pharmacy-lesson.pdf --timeout 60000 --wait 1500 && node scripts/fix-export.mjs --pdf",
    "export:pptx": "slidev export slides.md --format pptx --output ./output/illness-and-pharmacy-lesson.pptx --timeout 120000 --wait 1500 --wait-until load",
    "export:png": "slidev export slides.md --format png --output ./output/illness-and-pharmacy-lesson --timeout 120000 --wait 1500 --wait-until networkidle && node scripts/fix-export.mjs --png",
    "export:all": "bun run export:pdf && bun run export:pptx && bun run export:png"
  },
  "devDependencies": {
    "@slidev/cli": "^52.14.0",
    "@slidev/theme-default": "^0.25.0",
    "@slidev/theme-seriph": "^0.25.0",
    "@slidev/theme-apple-basic": "^0.25.0",
    "@slidev/theme-bricks": "^0.25.0",
    "slidev-theme-dracula": "^0.2.0",
    "playwright-chromium": "^1.52.0"
  }
}
